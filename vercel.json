{
  "rewrites": [
    {
      "source": "/og-api",
      "destination": "/api/og"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "s" },
        { "type": "query", "key": "magic", "value": "1" }
      ],
      "destination": "/api/og"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "s" },
        { "type": "header", "key": "user-agent", "value": ".*(Twitter|bot|facebook|Facebot|Slack|Discord|Google|WhatsApp|Link).*" }
      ],
      "destination": "/api/og"
    },
    {
      "source": "/index.html",
      "has": [
        { "type": "query", "key": "s" },
        { "type": "header", "key": "user-agent", "value": ".*(Twitter|bot|facebook|Facebot|Slack|Discord|Google|WhatsApp|Link).*" }
      ],
      "destination": "/api/og"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
